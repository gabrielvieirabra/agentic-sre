# ---- Local LLM (Ollama) ----
# Ollama runs on the host (Metal). No cloud APIs.
OLLAMA_BASE_URL=http://localhost:11434
# Primary model (strong tool-calling + JSON). Fallback: qwen2.5:3b
SRE_MODEL=qwen3:8b
SRE_MODEL_FALLBACK=qwen2.5:3b
# Deterministic-ish generation for agent reasoning
SRE_TEMPERATURE=0.1

# ---- Safety / mode ----
# One of: dry-run | suggest-only | apply-local-lab
SRE_MODE=dry-run
# Namespace lock. The agent refuses to touch anything else.
SRE_NAMESPACE=sre-lab
# kube context the agent is allowed to use (must be minikube for this project)
SRE_KUBE_CONTEXT=minikube

# ---- Loop guards ----
SRE_MAX_ITERATIONS=6
SRE_MAX_TOOL_CALLS=40
SRE_MAX_ELAPSED_SECONDS=600

# ---- Efficiency / capacity / cost ----
# Local cost is a cost-units proxy from resource requests; dollarization is optional.
SRE_MEM_COST_WEIGHT=0.5
SRE_CPU_TARGET_UTIL=0.7
SRE_PEAK_MULTIPLIER=2.0
# Set both > 0 to dollarize cost estimates (e.g., 0.04 $/vCPU-h, 0.005 $/GiB-h). 0 = units only.
SRE_PRICE_VCPU_HOUR=0
SRE_PRICE_GIB_HOUR=0

# ---- Observability / memory ----
SRE_RUNS_DIR=runs
SRE_MEMORY_DB=memory/sre_memory.sqlite
SRE_LOG_LEVEL=INFO
